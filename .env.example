# Copy this file to .env, fill in values, NEVER commit .env to git

# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# S3 buckets — create these names before running setup_aws.py
S3_BUCKET=                       # main data bucket (bronze/silver/gold)
ATHENA_RESULTS_BUCKET=           # separate bucket for Athena query results

# Athena
ATHENA_DATABASE=food_waste_db
ATHENA_WORKGROUP=food-waste-wg   # created by setup_aws.py

# Glue
GLUE_ROLE_NAME=FoodWasteGlueRole # IAM role created by setup_aws.py

# Local paths
DATA_DIR=data/raw                # path to macro_*.csv files
